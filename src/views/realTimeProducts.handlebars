<section class="panel">
  <h2>{{pageTitle}}</h2>
  <p class="panel-text">Alta y baja de productos</p>

  <div class="forms-grid">
    <form id="create-product-form" class="form-card">
      <h3>Crear producto</h3>

      <label for="title">Titulo</label>
      <input id="title" name="title" type="text" required />

      <label for="description">Descripcion</label>
      <input id="description" name="description" type="text" required />

      <label for="code">Code</label>
      <input id="code" name="code" type="text" required />

      <label for="price">Precio</label>
      <input id="price" name="price" type="number" min="0" required />

      <label for="stock">Stock</label>
      <input id="stock" name="stock" type="number" min="0" required />

      <label for="category">Categoria</label>
      <input id="category" name="category" type="text" required />

      <label for="thumbnails">Thumbnails</label>
      <input
        id="thumbnails"
        name="thumbnails"
        type="text"
        placeholder="Separadas por coma"
      />

      <label class="checkbox-field" for="status">
        <input id="status" name="status" type="checkbox" checked />
        Producto activo
      </label>

      <button type="submit">Crear producto</button>
    </form>

    <form id="delete-product-form" class="form-card">
      <h3>Eliminar producto</h3>

      <label for="productId">ID del producto</label>
      <input id="productId" name="productId" type="number" min="1" required />

      <button type="submit" class="danger-button">Eliminar producto</button>
    </form>
  </div>

  <p id="message" class="message"></p>

  <div class="table-wrapper">
    <table class="products-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Titulo</th>
          <th>Precio</th>
          <th>Categoria</th>
          <th>Stock</th>
        </tr>
      </thead>
      <tbody id="products-body">
        {{#if products.length}}
          {{#each products}}
            <tr>
              <td>{{this.id}}</td>
              <td>{{this.title}}</td>
              <td>${{this.price}}</td>
              <td>{{this.category}}</td>
              <td>{{this.stock}}</td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="5">No hay productos cargados.</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</section>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/realtimeproducts.js"></script>
